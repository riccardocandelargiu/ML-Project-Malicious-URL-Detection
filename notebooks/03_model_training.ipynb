    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Confusion matrix of the best model\\nShows which classes get confused with each other.\"\n",
    "   ],\n",
    "   \"id\": \"58b3a75d3ece1d1a\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
