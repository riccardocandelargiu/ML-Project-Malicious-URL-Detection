    "   \"source\": [\n",
    "    \"## Final comparison of the models\"\n",
    "   ],\n",
    "   \"id\": \"87c207b02453f8dd\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-07-15T17:05:20.468654500Z\",\n",
    "     \"start_time\": \"2026-07-15T17:05:19.447071200Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"res_df = pd.DataFrame(results).T.sort_values('macro_f1', ascending=False)\\nprint(res_df)\\nos.makedirs('figures', exist_ok=True)\\nres_df.plot(kind='bar', figsize=(8, 4))\\nplt.title('Model comparison (higher = better)')\\nplt.ylabel('score'); plt.ylim(0, 1); plt.xticks(rotation=0)\\nplt.tight_layout(); plt.savefig('figures/model_comparison.png', dpi=120); plt.show()\"\n",
    "   ],\n",
